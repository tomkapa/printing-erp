# Backend configuration. Copy to `.env` and load it before running the server:
#   set -a; source .env; set +a
# Keys map to nested settings: APP__<SECTION>__<FIELD> (double underscore).

# HTTP server
APP__SERVER__HOST=0.0.0.0
APP__SERVER__PORT=8080

# PostgreSQL (matches docker-compose.yml).
# URL is the least-privilege runtime role `erp_app` (NOSUPERUSER NOBYPASSRLS) so
# Row-Level Security applies — a superuser role would bypass it. ADMIN_URL is the
# owner role used ONLY to run migrations (DDL). If ADMIN_URL is omitted, URL is
# reused for migrations (only valid when URL is itself an admin role).
APP__DATABASE__URL=postgres://erp_app:erp_app@localhost:5432/erp
APP__DATABASE__ADMIN_URL=postgres://erp:erp@localhost:5432/erp
APP__DATABASE__MAX_CONNECTIONS=10
APP__DATABASE__ACQUIRE_TIMEOUT_SECS=5

# Redis (matches docker-compose.yml)
APP__REDIS__URL=redis://localhost:6379

# Object storage — S3-compatible (AWS S3 / Cloudflare R2 / MinIO).
# Local dev points at the MinIO service from docker-compose.
#   * AWS S3: omit ENDPOINT_URL, set a real REGION, FORCE_PATH_STYLE=false.
#   * Cloudflare R2: ENDPOINT_URL=https://<acct>.r2.cloudflarestorage.com, REGION=auto.
#   * MinIO (local): the values below.
# ENDPOINT_URL is baked into presigned URLs, so it must be reachable by the
# CLIENT that uploads/downloads (the browser) — use localhost here, not the
# docker-internal hostname.
APP__STORAGE__ENDPOINT_URL=http://localhost:9000
APP__STORAGE__REGION=us-east-1
APP__STORAGE__BUCKET=erp-assets
APP__STORAGE__ACCESS_KEY_ID=erp
APP__STORAGE__SECRET_ACCESS_KEY=erp_secret_dev
APP__STORAGE__FORCE_PATH_STYLE=true

# Telemetry
APP__TELEMETRY__SERVICE_NAME=erp-server
APP__TELEMETRY__LOG_LEVEL=info
# Uncomment to export spans to an OTLP/gRPC collector:
# APP__TELEMETRY__OTLP_ENDPOINT=http://localhost:4317

# Per-crate log filtering (overrides APP__TELEMETRY__LOG_LEVEL when set)
RUST_LOG=info,erp_server=debug,tower_http=debug
